# SchoolWallet Backend Configuration
# Copy this file to .env and update with your values

# Application
NODE_ENV=development
PORT=5000
APP_NAME=SchoolWallet

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=schoolwallet

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=1h

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000,http://localhost,https://your-domain.com

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@schoolwallet.edu

# SMS Configuration (optional)
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your-twilio-account-sid
SMS_AUTH_TOKEN=your-twilio-auth-token
SMS_FROM_NUMBER=+1-555-0100

# Payment Gateway
PAYMENT_GATEWAY=stripe
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME_MINUTES=15
SESSION_TIMEOUT_MINUTES=30
PASSWORD_MIN_LENGTH=8
REQUIRE_2FA=false

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Features
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_TRANSACTION_LIMITS=true
ENABLE_BATCH_SCHEDULING=true

# System Settings
DEFAULT_MONTHLY_LIMIT=3000
DEFAULT_DAILY_LIMIT=500
MAX_WITHDRAWAL_AMOUNT=5000
TRANSACTION_FEE_PERCENTAGE=0

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
